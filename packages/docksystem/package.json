{
  "name": "@primetimetran/beeline",
  "version": "1.1.0",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:js": "unbuild",
    "build:css": "npx @tailwindcss/cli -i ./src/styles.css -o ./dist/styles.css --minify",
    "build:all": "npm run build:js && npm run build:css",
    "release:patch": "npm run build:all && npm version patch && npm pack && mv primetimetran-docksystem-$(node -p \"require('./package.json').version\").tgz p.tgz"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "unbuild": "^3.6.1"
  }
}
