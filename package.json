{
  "name": "@primetimetran/blog",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "dev:debug": "NODE_OPTIONS='--inspect' next dev",
    "dev:watch": "concurrently \"node scripts/watch-terms.js\" \"next dev\"",
    "dev:socket": "cross-env SOCKET=true node ./scripts/next-remote-watch.js ./data",
    "prebuild": "cp tsconfig.build.json tsconfig.json",
    "build": "next build && node ./scripts/generate-sitemap.cjs",
    "serve": "next start",
    "analyze": "cross-env ANALYZE=true next build",
    "build:terms": "node scripts/build-terms.js",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --fix",
    "lint:strict": "eslint . --max-warnings=0",
    "prepare": "husky install",
    "clean": "rm -rf .next node_modules/.cache",
    "test": "vitest run",
    "start": "vitest run",
    "hmr-iframe": ""
  },
  "dependencies": {
