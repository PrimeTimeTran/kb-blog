{
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2020"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "resolveJsonModule": true,
    "jsx": "preserve",
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "incremental": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "types": [
      "node"
    ],
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/app/*": [
        "./app/*"
      ],
      "@/components/*": [
        "./components/*"
      ],
      "@/data/*": [
        "./data/*"
      ],
      "@/hooks/*": [
        "./hooks/*"
      ],
      "@/layouts/*": [
        "./layouts/*"
      ],
      "@/lib/*": [
        "./lib/*"
      ],
      "@/mdx/*": [
        "./components/mdx/*"
      ],
      "@/providers/*": [
        "./providers/*"
      ]
    },
    "allowJs": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "lib/sort-tree.js"
  ],
  "exclude": [
    "node_modules",
    ".next"
  ]
}
