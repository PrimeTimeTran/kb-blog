  "todo-tree.tree.scanAtStartup": false,
  "todo-tree.highlights.enabled": false,
  "todo-tree.general.tags": [
    "TODO",
    "todo",
    "BUG",
    "FIX",
    "FIXME",
    "fix",
    "fixme",
    "MARK",
    "mark",
    "trail",
    "route",
    "flow",
    "PATH",
  ],
  "todo-tree.general.tagGroups": {
    "TODO": ["TODO", "todo"],
    "BUG": ["BUG", "FIX", "FIXME", "fix", "fixme"],
    "MARK": ["MARK", "mark"],
    "Trail": ["path", "Trail", "route", "flow", "follow"],
  },
  "todo-tree.regex.regex": "((//|#|<!--|;|/\\*|^)((\\s+(!|\\?|\\*|\\-))?(\\s+\\[ \\])?|(\\s+(!|\\?|\\*)\\s+\\[.\\])?)\\s*($TAGS)\\s*\\:)",
  "todo-tree.highlights.customHighlight": {
    "TODO": {
      "icon": "checklist",
    },
    "BUG": {
      "icon": "bug",
    },
    "MARK": {
      "icon": "bookmark",
    },
    "PATH": {
      "icon": "bookmark",
    },
    "MARK": {
      "icon": "bookmark",
    },
    "Trail": {
      "icon": "bookmark",
    },
  },
  "todo-tree.tree.labelFormat": "${tag:uppercase} ${after} [${filename}]",
  "todo-tree.tree.tooltipFormat": "${filename}:[${line}] in ${filepath}",
